	// Surlignage temporaire vert/rouge, indépendant du système highlightedValue/replacementValue des animations
	private Integer feedbackFlashValue = null;
	private boolean feedbackFlashCorrect = false;

	public void flashFeedback(Integer value, boolean correct) {
		feedbackFlashValue = value;
		feedbackFlashCorrect = correct;
		repaint();
		javax.swing.Timer t = new javax.swing.Timer(1400, e -> {
			((javax.swing.Timer) e.getSource()).stop();
			feedbackFlashValue = null;
			repaint();
		});
		t.setRepeats(false);
		t.start();
	}
