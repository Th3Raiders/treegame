package tree;

import java.util.Comparator;
import java.util.function.Function;

import node.ValuedNode;

public class StdBSTTree<N extends ValuedNode<N, T>, T> extends StdTree<N> implements BSTTree<N, T> {

	// ATTRIBUTS 
	
	private final Comparator<T> comparator;
	private final Function<T, N> factory;
	
	
	private static final int REPR__TAB = 4;
	
	// CONSTRUCTEURS

	public StdBSTTree(Comparator <T> c,Function<T, N> f) {
		this.comparator = c;
		this.factory = f;
		this.root = null;
	}

	public StdBSTTree(Comparator <T> c, Function<T, N> f,N n) {
		this.comparator = c;
		this.factory = f;
		this.root = n;
	}
	
	// REQUETES
	
	@Override
	public boolean isIn(T x) {
		return search(x,getRoot());
	}

	@Override
	public Comparator<T> getComparator() {
		return this.comparator;
	}

	
	// COMMANDES
	
	@Override
	public void add(T x) {
		this.setRoot(addValue(x,getRoot()));
	}

	@Override
	public void delete(T x) {
		// TODO Auto-generated method stub
		this.setRoot(deleteValue(x,getRoot()));
	}
	
