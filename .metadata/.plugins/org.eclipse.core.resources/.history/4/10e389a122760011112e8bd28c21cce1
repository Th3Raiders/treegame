	public void printTree() {
	    printTreeAux(root, "", true);
	}

	// OUTILS
	
	
	private void printTreeAux(N node, int level) {
	    if (node == null) {
	        System.out.println(" ".repeat(REPR__TAB * level) + "|");
	    } else {
	        printTreeAux(node.getRight(), level + 1);

	        System.out.println(
	            " ".repeat(REPR__TAB * level) + node.getValue()
	        );

	        printTreeAux(node.getLeft(), level + 1);
	    }
	}

	
	public boolean search(T value,N node) {
		if(node == null) {
			return false;
		}
		int c = comparator.compare(value,node.getValue());
		if(c == 0) {
			return true;
		}
		if(c < 0) {
			return search(value,node.getLeft());
		} else {
			return search(value,node.getRight());
		}
	}
	
	public N addValue(T value,N node) {
		if(node == null) {
			return factory.apply(value);
		}
		int c = comparator.compare(value,node.getValue());
		if(c == 0) {
			return node;
		}
		if(c < 0) {
			node.setLeft(addValue(value,node.getLeft()));
		} else {
			node.setRight(addValue(value,node.getRight()));
		}
		return node;
	}
	
	
	
	
	
	
	
	public N deleteValue(T value,N node) {
		if(node == null) {
			return null;
		}
		int c = comparator.compare(value,node.getValue());
		if(c == 0) {
			// ON SUPPRIME
			
			// ON TRAITE LES 3 CAS POSSIBLES
			
			if(node.getLeft() == null && node.getRight() == null) {
				return null;
			}
			if (node.getLeft() == null && node.getRight() != null) {
			    return node.getRight();
			}
			if (node.getLeft() != null && node.getRight() == null) {
			    return node.getLeft();
			}
			
			T x = findSmallestValue(node.getRight());
			node.setValue(x);
			node.setRight(deleteValue(x,node.getRight()));
			return node;
			
		}
		if(c < 0) {
			node.setLeft(deleteValue(value,node.getLeft()));
		} else {
			node.setRight(deleteValue(value,node.getRight()));
		}
		return node;
	}
	
	
	
	
	
	private T findSmallestValue(N n) {
		return n.getLeft() == null ? n.getValue() : findSmallestValue(n.getLeft());
	}
	
}
