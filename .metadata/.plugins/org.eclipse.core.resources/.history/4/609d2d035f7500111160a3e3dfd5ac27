package node;

public class StdValuedNode<T> implements Node<StdValuedNode<T>> {

	// ATTRIBUTS

	protected StdValuedNode<T> left;
	protected StdValuedNode<T> right;
	private T value;

	// CONSTRUCTEURS
	
	public StdValuedNode(T v) {
		this.left = null;
		this.right = null;
		this.value = v;
	}
	
	// REQUETES
	
	@Override
	public StdValuedNode<T> getLeft() {
		return left;
	}

	@Override
	public StdValuedNode<T> getRight() {
		return right;
	}
	
	public T getValue() {
		return value;
	}

	// COMMANDES

	@Override
	public void setLeft(StdValuedNode<T> n) {
		this.left = n;
	}

	@Override
	public void setRight(StdValuedNode<T> n) {
		this.right = n;
	}

	public void setValeur(T v) {
		this.value = v;
	}

}
