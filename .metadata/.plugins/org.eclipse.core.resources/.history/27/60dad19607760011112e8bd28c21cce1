package node;

public class StdValuedNode<T> implements ValuedNode<StdValuedNode<T>, T> {

	// ATTRIBUTS

	protected StdValuedNode<T> left;
	protected StdValuedNode<T> right;
	private T value;

	// CONSTRUCTEURS

	public StdValuedNode(T v) {
		this.left = null;
		this.right = null;
		this.value = v;
	}

	// REQUETES

	@Override
	public StdValuedNode<T> getLeft() {
		return this.left;
	}

	@Override
	public StdValuedNode<T> getRight() {
		return this.right;
	}

	public T getValue() {
		return this.value;
	}
	
	// COMMANDES

	@Override
	public void setLeft(StdValuedNode<T> n) {
		this.left = n;
	}

	@Override
	public void setRight(StdValuedNode<T> n) {
		this.right = n;
	}

	@Override
	public void setValeur(T v) {
		this.valeur = v;
	}


}