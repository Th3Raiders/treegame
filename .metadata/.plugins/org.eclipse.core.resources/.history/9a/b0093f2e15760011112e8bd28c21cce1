	public void printTree() {
		printTreeAux(this.getRoot(),1);
	}

	// OUTILS
	
	
	private void printTreeAux(N node,int level) {
		if(node == null) {
			printf("")
		}
	}
	
	public boolean search(T value,N node) {
		if(node == null) {
			return false;
		}
		int c = comparator.compare(value,node.getValue());
		if(c == 0) {
			return true;
		}
		if(c < 0) {
			return search(value,node.getLeft());
		} else {
			return search(value,node.getRight());
		}
	}
	
	public N addValue(T value,N node) {
		if(node == null) {
			return factory.apply(value);
		}
		int c = comparator.compare(value,node.getValue());
		if(c == 0) {
			return node;
		}
		if(c < 0) {
			node.setLeft(addValue(value,node.getLeft()));
		} else {
			node.setLeft(addValue(value,node.getRight()));
		}
		return node;
	}
	
}
