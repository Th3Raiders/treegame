package tree;

import java.util.Comparator;

import node.ValuedNode;

public interface BSTTree<N extends ValuedNode<N, T>, T> extends Tree<N> {
	//REQUETES
	
    /**
     * Modifie la valeur du noeud.
     * @pre <pre>
     *     x != null </pre>
     */
	public boolean isIn(T x);
	
	public Comparator<T> getComparator();
	
	// COMMANDES
	
	public void add(T x);
	
	public void delete(T x);
	
	public void printTree();
}
