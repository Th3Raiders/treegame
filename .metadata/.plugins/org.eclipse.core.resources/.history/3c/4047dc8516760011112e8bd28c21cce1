package node;

public interface Node<N extends Node<N>> {
	
	
    // REQUETES
    
    /**
     * Le sous arbre gauche.
     */
	public N getLeft();
	
	
    /**
     * Le sous arbre droit.
     */
	public N getRight();
	
	// COMMANDES
	
	
    /**
     * Changer le sous arbre gauche.
     */
	public void setLeft(N n);
	
    /**
     * Changer le sous arbre droit.
     */
	public void setRight(N n);
}