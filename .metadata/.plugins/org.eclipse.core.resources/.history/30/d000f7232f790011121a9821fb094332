    		private final Map<StdValuedNode<Integer>, Point2D.Double> positions = new IdentityHashMap<>();
    		private int inorderCounter;

    		private boolean animationMode = false;
    		private Integer highlightedValue = null;
    		private Integer replacementValue = null;

    		private boolean stepMode = false;
    		private List<Integer> pendingPath = null;
    		private int pendingIndex = 0;
    		private Runnable pendingFinalAction = null;
    		private Runnable pendingOnFinished = null; // NOUVEAU

    		private boolean busy = false; // NOUVEAU

    		// CONSTRUCTEURS
    		public BSTPanel() {
    			setupNavigation();
    			setBackground();
    		}

    		// REQUETES

    		public BSTTree<StdValuedNode<Integer>, Integer> getModel() {
    			return model;
    		}

    		public boolean isBusy() { // NOUVEAU
    			return busy;
    		}

    		public boolean isAnimating() {
    			return pendingPath != null;
    		}

    		public boolean searchInt(Integer i) {
    			return model.isIn(i);
    		}

    		// COMMANDES

    		public void addInt(Integer i) { // MODIFIÉ : délègue à la version avec callback
    			addInt(i, null);
    		}

    		public void addInt(Integer i, Runnable onFinished) { // NOUVEAU
    			if (busy) {
    				return;
    			}
    			if (!animationMode) {
    				model.add(i);
    				repaint();
    				if (onFinished != null) {
    					onFinished.run();
    				}
    				return;
    			}
    			busy = true;
    			List<Integer> path = computeSearchPath(i);
    			model.add(i);
    			if (stepMode) {
    				startStepAnimation(path, null, onFinished);
    			} else {
    				animatePath(path, onFinished);
    			}
    		}

    		public void deleteInt(Integer i) { // MODIFIÉ
    			deleteInt(i, null);
    		}

    		public void deleteInt(Integer i, Runnable onFinished) { // NOUVEAU
    			if (busy) {
    				return;
    			}
    			if (!animationMode) {
    				model.delete(i);
    				repaint();
    				if (onFinished != null) {
    					onFinished.run();
    				}
    				return;
    			}
    			if (!model.isIn(i)) {
    				if (onFinished != null) {
    					onFinished.run();
    				}
    				return;
    			}
    			busy = true;
    			List<Integer> path = computeDeletePath(i);
    			if (stepMode) {
    				startStepAnimation(path, () -> model.delete(i), onFinished);
    			} else {
    				animateThenDelete(path, i, onFinished);
    			}
    		}

    		private void animateThenDelete(List<Integer> path, int valueToDelete, Runnable onFinished) { // MODIFIÉ
    			final int[] index = {0};
    			Timer timer = new Timer(500, null);
    			timer.addActionListener(e -> {
    				if (index[0] < path.size()) {
    					highlightedValue = path.get(index[0]);
    					repaint();
    					index[0]++;
    				} else {
    					timer.stop();
    					highlightedValue = null;
    					replacementValue = null;
    					model.delete(valueToDelete);
    					repaint();
    					busy = false; // NOUVEAU
    					if (onFinished != null) { // NOUVEAU
    						onFinished.run();
    					}
    				}
    			});
    			timer.start();
    		}

    		private void startStepAnimation(List<Integer> path, Runnable finalAction, Runnable onFinished) { // MODIFIÉ
    			pendingPath = path;
    			pendingIndex = 0;
    			pendingFinalAction = finalAction;
    			pendingOnFinished = onFinished; // NOUVEAU
    			highlightedValue = null;
    			repaint();
    		}

    		public void nextStep() { // MODIFIÉ
    			if (pendingPath == null) {
    				return;
    			}
    			if (pendingIndex < pendingPath.size()) {
    				highlightedValue = pendingPath.get(pendingIndex);
    				pendingIndex++;
    				repaint();
    			} else {
    				highlightedValue = null;
    				replacementValue = null;
    				if (pendingFinalAction != null) {
    					pendingFinalAction.run();
    				}
    				Runnable finished = pendingOnFinished; // NOUVEAU
    				pendingPath = null;
    				pendingFinalAction = null;
    				pendingOnFinished = null; // NOUVEAU
    				busy = false; // NOUVEAU
    				repaint();
    				if (finished != null) { // NOUVEAU
    					finished.run();
    				}
    			}
    		}

