package binarytree;

public class StdTree implements Tree {

	private Node root;
	
	// CONSTRUCTEURS
	
	public StdTree() {
		this.root = null;
	}
	
	public StdTree(Node n) {
		this.root = n;
	}
	
	@Override
	public Node getRoot() {
		return this.root;
	}

	@Override
	public boolean isEmpty() {
		return this.root == null;
	}
	
	@Override
	public int getSize() {
		return getSizeAux(getRoot());
	}

	@Override
	public int getHeight() {
		return getHeightAux(getRoot());
	}

	@Override
	public int getDistance() {
		return getDistanceAux(getRoot());
	}

	@Override
	public void setRoot(Node n) {
		this.root = n;
	}
	
	
	
	// Fonctions Auxiliaires
	
	public int getSizeAux(Node n) {
		if(n == null) {
			return 0;
		}
		return 1 + getSizeAux(n.getLeft()) + getSizeAux(n.getRight());
	}
	
	public int getHeight(Node n) {
		if(n == null) {
			return 0;
		}
		return 1 + getSizeAux(n.getLeft()) + getSizeAux(n.getRight());
	}
	
	public int getDistance(Node n) {
		if(n == null) {
			return 0;
		}
		return 1 + getSizeAux(n.getLeft()) + getSizeAux(n.getRight());
	}
	
}
