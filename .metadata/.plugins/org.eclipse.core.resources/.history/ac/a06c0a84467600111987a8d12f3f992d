package node;

public abstract class AbstractValuedNode<N extends ValuedNode<N, T>, T> implements ValuedNode<N, T> {
	
	// ATTRIBUTS

	protected N left;
	protected N right;
	private T value;
	
	// CONSTRUCTEURS

	public AbstractValuedNode(T v) {
		this.left = null;
		this.right = null;
		this.value = v;
	}

	// REQUETES

		@Override
		public N getLeft() { return left; }

		@Override
		public N getRight() { return right; }

		@Override
		public T getValue() { return valeur; }

	
}
