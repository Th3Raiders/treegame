package binarytree;

public class StdTree implements Tree {

	private Node root;
	
	// CONSTRUCTEURS
	
	public StdTree() {
		this.root = null;
	}
	
	public StdTree(Node n) {
		this.root = n;
	}
	
	@Override
	public Node getRoot() {
		return this.root;
	}

	@Override
	public boolean isEmpty() {
		// TODO Auto-generated method stub
		return false;
	}
	
	@Override
	public int getSize() {
		// TODO Auto-generated method stub
		return 0;
	}

	@Override
	public int getHeight() {
		// TODO Auto-generated method stub
		return 0;
	}

	@Override
	public int getDistance() {
		// TODO Auto-generated method stub
		return 0;
	}

	@Override
	public void setRoot(Node n) {
		this.root = n;
	}
	
	
	
	// Fonctions Auxiliaires
	
	public int getRootAux(Node n) {
		if(n == null) {
			return 0;
		}
		return 1 + getRootAux(n.getLeft()) + getRootAux(n.getRight());
	}
	
}
