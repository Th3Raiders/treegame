package utils;

import java.awt.Color;
import java.awt.Graphics;
import java.awt.Graphics2D;
import java.awt.RenderingHints;

import javax.swing.JPanel;

public class StyledTabbedPane extends JPanel {

	private static final Color BACKGROUND_COLOR = new Color(245, 245, 247); // gris très clair
	private static final int ARC = 24; // rayon des coins arrondis

	public StyledTabbedPane() {
		setOpaque(false); // NOUVEAU : on gère nous-mêmes le fond, pas Swing
	}

	@Override
	protected void paintComponent(Graphics g) {
		Graphics2D g2 = (Graphics2D) g.create();
		g2.setRenderingHint(RenderingHints.KEY_ANTIALIASING, RenderingHints.VALUE_ANTIALIAS_ON);

		g2.setColor(BACKGROUND_COLOR);
		g2.fillRoundRect(0, 0, getWidth(), getHeight(), ARC, ARC); // NOUVEAU : fond arrondi

		g2.dispose();
		super.paintComponent(g); // dessine les composants enfants (boutons, labels) par-dessus
	}
}