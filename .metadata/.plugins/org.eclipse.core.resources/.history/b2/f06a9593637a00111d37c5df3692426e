                q.add(replayButton);
        	} //--
        	p.add(q,BorderLayout.NORTH);
        	q = new JPanel(new BorderLayout());
        	{ //--
        		JPanel r = new JPanel();
        		{ //--
        		    r.add(preorderButton);
        		    r.add(inorderButton);
        		    r.add(postorderButton);
        		    r.add(levelOrderButton);
        		} //--
        		q.add(r,BorderLayout.NORTH);
        		r = new JPanel();
        		{ //--
            		r.add(animationCheckBox);	
