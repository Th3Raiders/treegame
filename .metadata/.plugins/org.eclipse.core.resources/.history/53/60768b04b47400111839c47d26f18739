package binarytree;

public interface Node {
	
	
    // REQUETES
    
    /**
     * Le sous arbre gauche du noeud.
     */
	public Node getLeft();
	
	
    /**
     * Le sous arbre droit du noeud.
     */
	public Node getRight();
	
	// COMMANDES
	
	
    /**
     * Changer le sous arbre gauche du noeud.
     * @pre
     * 	 n != null
     */
	public void setLeft(Node n);
	
    /**
     * Changer le sous arbre droit du noeud.
     * @pre
     * 	 n != null
     */
	public void setRight(Node n);
}