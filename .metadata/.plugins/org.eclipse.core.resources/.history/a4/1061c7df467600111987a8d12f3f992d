package node;

public class StdAVLNode<T> extends AbstractValuedNode<StdAVLNode<T>, T> implements AVLNode<StdAVLNode<T>, T> {

	private int height;

	public StdAVLNode(T v) {
		super(v);
		this.height = 0;
	}

	@Override
	public int getHeight() { return height; }

	@Override
	public void setHeight(int h) { this.height = h; }

}
