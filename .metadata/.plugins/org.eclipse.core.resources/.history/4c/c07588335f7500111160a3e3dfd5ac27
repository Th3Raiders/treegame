/* Interface permettant de disposer des opérations classiques sur les arbres
 * @inv <pre>
 * 		getHeight() >= 0
 * 		getSize() >= 0
 * 		getDistance() >= 0	
 * 		isEmpty() <==> getRoot() == null </pre>
 * @cons <pre>
 *     $ARGS$ -
 *     $POST$
 *         getSize() == 0
 *         getHeight() == 0
 *         getDistance() == 0
 *         isEmpty()
 *         getRoot() == null </pre>
 *  @cons <pre>
 *     $ARGS$ Node n
 *     $POST$
 *         getSize() == la taille de l'arbre associé au noeud n
 *         getHeight() == la hauteur de l'arbre associé au noeud n
 *         getDistance() == la distance de l'arbre associé au noeud n
 *         !isEmpty()
 *         getRoot() == n </pre>
 */

package tree;

import node.Node;


public interface Tree<N extends Node<N>> {
	N getRoot();
	void setRoot(N n);
	
	public boolean isEmpty();
	
	public int getSize();
	
	public int getHeight();
	
	public int getDistance();
}

public interface Tree {
	
	
    // REQUETES
	
	public Node getRoot();
	
	public boolean isEmpty();
	
	public int getSize();
	
	public int getHeight();
	
	public int getDistance();
	
	// COMMANDES
	
	
	public void setRoot(Node n);
	
}
