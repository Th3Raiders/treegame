/*
 * @inv <pre>
 * 		getHeight() >= 0
 * 		getSize() >= 0
 * 		getDistance() >= 0	
 * 		isEmpty() <==> getRoot() == null </pre>
 * @cons <pre>
 *     $ARGS$ -
 *     $POST$
 *         getSize() == 0
 *         getHeight() == 0
 *         getDistance() == 0
 *         isEmpty()
 *         getRoot() == null </pre>
 *  @cons <pre>
 *     $ARGS$ Node n
 *     $POST$
 *         getSize() == la taille de l'arbre associé au noeud n
 *         getHeight() == la hauteur de l'arbre associé au noeud n
 *         getDistance() == la taille de l'arbre associé au noeud n
 *         !isEmpty()
 *         getRoot() == n </pre>
 */

package binarytree;

public interface Tree {
	
	
    // REQUETES
	
	public Node getRoot();
	
	public boolean isEmpty();
	
	public int getSize();
	
	public int getHeight();
	
	public int getDistance();
	
	// COMMANDES
	
	
	public void setRoot(Node n);
	
}
