package binarytree;

import java.awt.BorderLayout;
import java.awt.Dimension;
import java.awt.event.ActionEvent;
import java.awt.event.ActionListener;

import javax.swing.JButton;
import javax.swing.JCheckBox;
import javax.swing.JFrame;
import javax.swing.JLabel;
import javax.swing.JOptionPane;
import javax.swing.JPanel;
import javax.swing.JTabbedPane;
import javax.swing.SwingUtilities;

import utils.StyledButton;
import utils.StyledTabbedPane;

public class Treegame {
	
	
	// ATTRIBUTS D'INSTANCE
		
	
	
	private static final int GEN_NUMBER = 10;
	private static final int GEN_MAX = 100;
	private static final int GEN_MIN = 1;
	
	private static final int FRAME_WIDTH = 1400;
	private static final int FRAME_HEIGHT = 800;
	
	private JFrame frame;
	
	private JButton addButton;
	private JButton deleteButton;
	private JButton searchButton;
	private JButton generateButton;
	private JButton resetButton;
	
	
	private JLabel heightLabel;
	private JLabel sizeLabel;
	private JLabel distanceLabel;
	
	private BSTPanel bstPanel;
	private AVLPanel avlPanel;
	
	private JCheckBox animationCheckBox;
	
	// CONSTRUCTEURS
	
	public Treegame() {
		 this.frame = createFrame();
		 this.addButton = new StyledButton("Ajouter une valeur");
		 this.deleteButton = new StyledButton("Supprimer une valeur");
		 this.searchButton = new StyledButton("Chercher une valeur");
		 this.generateButton = new StyledButton("Générer un arbre");
		 this.resetButton = new StyledButton("Supprimer l'arbre");
		 this.heightLabel = new JLabel("Hauteur : 0");
		 this.sizeLabel = new JLabel("Taille : 0");
		 this.distanceLabel = new JLabel("Distance : 0");
		 this.bstPanel = new BSTPanel();
		 this.avlPanel = new AVLPanel();
		 
		 this.animationCheckBox = new JCheckBox("Mode animation");
		 
		 placeComponents();
		 connectControllers();
	}
	// COMMANDES
	
	public void display() {
		refresh();
		frame.pack();
	    frame.setLocationRelativeTo(null);
	    frame.setVisible(true);
	}
	// OUTILS
	
	 private JFrame createFrame() {	        
	        JFrame f = new JFrame("Jeu d'arbre");
	        f.setPreferredSize(new Dimension(FRAME_WIDTH, FRAME_HEIGHT));
	        return f;
	 }
	    
	 
    private void placeComponents() {
        JPanel p = new JPanel(new BorderLayout());
        { //--
        	JPanel q = new JPanel();
        	{ //--
                q.add(addButton);
                q.add(deleteButton);
                q.add(searchButton);
                q.add(generateButton);
                q.add(resetButton);
        	} //--
        	p.add(q,BorderLayout.NORTH);
        	q = new JPanel();
        	{ //--
        		q.add(animationCheckBox);	
        	} //--
        	p.add(q,BorderLayout.CENTER);
        	q = new JPanel();
        	{ //--
        		q.add(heightLabel);
        		q.add(sizeLabel);
        		q.add(distanceLabel);
        	} //--
        	p.add(q,BorderLayout.SOUTH);
        } //--
        frame.add(p, BorderLayout.NORTH);
        JTabbedPane q = new StyledTabbedPane() ;
        {//--
        	q.addTab("ABR",bstPanel);
        	q.addTab("AVL",avlPanel);
        }//--
        frame.add(q,BorderLayout.CENTER);
    } 
	
    private void connectControllers() {
    	addButton.addActionListener(new ActionListener() {

			@Override
			public void actionPerformed(ActionEvent arg0) {
				String vs = JOptionPane.showInputDialog(null,"Entrez la valeur.");
				if(vs != null) {
					System.out.println("La valeur entré est : " + Integer.parseInt(vs));
					bstPanel.addInt(Integer.parseInt(vs));
					avlPanel.addInt(Integer.parseInt(vs));
				}
			}
    		
    	});
    	
    	deleteButton.addActionListener(new ActionListener() {

			@Override
			public void actionPerformed(ActionEvent arg0) {
				String vs = JOptionPane.showInputDialog(null,"Entrez la valeur.");
				if(vs != null) {
					System.out.println("La valeur entré est : " + Integer.parseInt(vs));
					bstPanel.deleteInt(Integer.parseInt(vs));
					avlPanel.deleteInt(Integer.parseInt(vs));
				}
			}
    		
    	});
    	
     	searchButton.addActionListener(new ActionListener() {

			@Override
			public void actionPerformed(ActionEvent arg0) {
				String vs = JOptionPane.showInputDialog(null,"Entrez la valeur.");
				if(vs != null) {
					System.out.println("La valeur entré est : " + Integer.parseInt(vs));
					bstPanel.deleteInt(Integer.parseInt(vs));
					avlPanel.deleteInt(Integer.parseInt(vs));
				}
			}
    		
    	});
     	
     	generateButton.addActionListener(new ActionListener() {

			@Override
			public void actionPerformed(ActionEvent arg0) {
				for(int i = 0; i < GEN_NUMBER; i++) {
					int r = getRandom(GEN_MIN,GEN_MAX);
					bstPanel.addInt(r);
					avlPanel.addInt(r);
				}
			}
     		
     	});
     	
     	resetButton.addActionListener(new ActionListener() {

			@Override
			public void actionPerformed(ActionEvent arg0) {
				bstPanel.getModel().setRoot(null);
				bstPanel.repaint();
			}
     		
     	});
     	
     	
     	animationCheckBox.addActionListener(new ActionListener() {
     	    @Override
     	    public void actionPerformed(ActionEvent arg0) {
     	        boolean enabled = animationCheckBox.isSelected();
     	        bstPanel.setAnimationMode(enabled);
     	        avlPanel.setAnimationMode(enabled);
     	    }
     	});
    }
    
	private void refresh() {
		
	}
	
	
	
	private static int getRandom(int min, int max) {
		int range = (max - min) + 1;
     	int random = (int) ((range * Math.random()) + min);
		return random;
	}
	
	
	// POINT D'ENTREE
	
	public static void main(String[] args) {
		SwingUtilities.invokeLater(new Runnable() {
            @Override
            public void run() {
                new Treegame().display();
            }
		});
	}
}