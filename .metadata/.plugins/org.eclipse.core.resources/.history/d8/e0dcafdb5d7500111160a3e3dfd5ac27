package binarytree;

public class StdNode implements Node<StdNode> {

	// ATTRIBUTS

	protected StdNode left;
	protected StdNode right;

	// CONSTRUCTEURS

	public StdNode() {
		this.left = null;
		this.right = null;
	}

	// REQUETES

	@Override
	public StdNode getLeft() {
		return left;
	}

	@Override
	public StdNode getRight() {
		return right;
	}

	// COMMANDES

	@Override
	public void setLeft(StdNode n) {
		this.left = n;
	}

	@Override
	public void setRight(StdNode n) {
		this.right = n;
	}

}